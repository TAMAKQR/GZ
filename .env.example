TELEGRAM_BOT_TOKEN=123456789:telegram_bot_token_here

# Use these for the two Telegram groups. Group IDs usually start with -100.
ARTO_CHAT_ID=
CATERING_CHAT_ID=

# Optional fallback for one private chat during local testing.
TELEGRAM_CHAT_ID=

PORTAL_URL=https://goszakupki.okmot.kg/public/home
API_URL=https://goszakupki.okmot.kg/api/public_tender/published?first=0&rows=100
API_ROWS=100
CHECK_INTERVAL_MINUTES=10

# Base profiles already include common words. Add extra words if needed.
ARTO_FILTER_KEYWORDS=
CATERING_FILTER_KEYWORDS=
NOTIFY_ONLY_RELEVANT=true
EXCLUDED_STATUSES=CONTRACT_SIGNED,CANCELLED,CANCELED

# API mode is faster. Browser mode remains available as a fallback.
SCRAPER_MODE=api
HEADLESS=true
ARTO_DATA_FILE=data/seen-arto.json
CATERING_DATA_FILE=data/seen-catering.json

# Optional selectors if the portal layout changes.
ITEM_SELECTOR=tr, article, .card, .ant-card, .mat-card, [class*="tender"], [class*="purchase"], [class*="lot"]
LINK_SELECTOR=a[href]
ORDER_LINK_SELECTOR=a[href*="/public/order/view/"]
